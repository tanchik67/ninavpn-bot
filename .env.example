# ═══════════════════════════════════════════
#  NINAVPN BOT — переменные окружения
#  Скопируй в .env и заполни свои значения
# ═══════════════════════════════════════════

# Telegram Bot (получить у @BotFather)
BOT_TOKEN=1234567890:AAxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Числовой Telegram ID администратора (у @userinfobot команда /start). Должен совпадать с тем, кто пишет /admin
ADMIN_ID=123456789
# Дополнительные админы (ID через запятую, без пробелов). Команда /admin и остальные админ-команды
ADMIN_IDS=

# Ссылка на оферту / условия (кнопка в главном меню, опционально)
TERMS_URL=
# Поддержка: через бота («Написать в поддержку»). SUPPORT_URL в клавиатуре не используется.
SUPPORT_URL=
# Канал: если задан CHANNEL_USERNAME и/или CHANNEL_ID — бот пускает только подписанных (getChatMember).
# Для публичного канала достаточно CHANNEL_USERNAME (рекомендуется); CHANNEL_ID — опционально.
# Бот должен быть администратором канала, иначе API вернёт ошибку и проверка временно отключится в логах.
# Оставьте оба пустыми — проверка отключена.
CHANNEL_ID=
CHANNEL_USERNAME=ninavpn_official

# Telegram Mini App: полный HTTPS-URL (как в браузере), совпадает с кнопкой и с доменом в @BotFather → Bot → Configure Mini App
# Пример: https://ваш-домен/miniapp/  (nginx проксирует /miniapp/ на тот же порт 8080, что и /payment/)
MINI_APP_URL=
# Юзернейм бота без @ — кнопка «Оформить в боте» внутри Mini App
BOT_USERNAME=
# PNG баннер тарифов при /start (путь от корня проекта). По умолчанию ищется assets/welcome_tariffs.png
# Отключить картинку: WELCOME_BANNER_FILE=none
# WELCOME_BANNER_FILE=assets/welcome_tariffs.png

# ─── Панель VPN ────────────────────────────
# marzban — Marzban API | xui — 3x-ui (MHSanaei)
VPN_BACKEND=marzban

# ─── Marzban (если VPN_BACKEND=marzban) ────
# База для API: должен отвечать FastAPI (POST /api/admin/token). Проверка: curl -X POST .../api/admin/token
# Если публичный домен отдаёт только HTML с Cloudflare (405 на token) — задайте MARZBAN_API_URL на реальный порт Marzban.
MARZBAN_URL=https://vpn.ninavpn.store
MARZBAN_API_URL=
MARZBAN_USERNAME=admin
MARZBAN_PASSWORD=ваш_пароль
# Имя inbound в Marzban должно совпадать с панелью (иначе 422 при создании пользователя).
MARZBAN_VLESS_INBOUND=VLESS TCP REALITY
MARZBAN_VLESS_FLOW=xtls-rprx-vision
# max_ips в API Marzban = одновременные разные IP по одной подписке (как «N устройств»). false — не слать поле (если Marzban отвечает 422).
MARZBAN_SEND_MAX_IPS=true

# ─── 3x-ui (если VPN_BACKEND=xui) ──────────
# URL панели без слэша в конце (например https://IP:2053)
XUI_URL=
# Если панель в подпапке — префикс пути (часто пусто)
XUI_PATH_PREFIX=
XUI_USERNAME=
XUI_PASSWORD=
# При 2FA в панели
XUI_2FA_CODE=
# ID inbound из панели (число)
XUI_INBOUND_ID=1
# Публичный базовый URL подписки (без / в конце). Пусто = {схема}://{хост}:{XUI_SUB_PORT или порт XUI_URL}/{XUI_SUB_PATH}/{subId}
XUI_SUBSCRIPTION_BASE=
# Порт sub в 3x-ui (часто 2096). Без этого бот пробует порт панели → 404 на /sub/
XUI_SUB_PORT=2096
# Если XUI_SUB_PORT пуст: доп. порты для запроса /sub/ через запятую (по умолчанию в коде — 2096)
# XUI_SUB_FALLBACK_PORTS=2096,8443
# URI Path подписки в панели (по умолчанию sub); если меняли — укажите тот же сегмент без слэшей
XUI_SUB_PATH=sub
# true — проверять TLS при GET подписки /sub/…; false — для панели по IP с самоподписанным сертификатом
XUI_SUBSCRIPTION_FETCH_VERIFY_SSL=false
# Проверка TLS к API панели (логин, inbounds). false — если сертификат HTTPS панели истёк или самоподписанный
# XUI_VERIFY_SSL=false
# Для зеркала: в объекте узла в XUI_NODES можно задать "verify_ssl": false только для одной ноды
# Flow для VLESS в клиенте (например xtls-rprx-vision) или пусто. Лимит устройств в 3x-ui — limitIp на клиенте; на inbound в панели должно быть включено ограничение по IP.
XUI_CLIENT_FLOW=

# Пинг в «Серверы / статус» и сортировка узлов по скорости (первый vless = самый быстрый узел)
# SERVER_STATUS_CACHE_SEC=90
# SERVER_PING_TIMEOUT_SEC=4
# SERVER_PING_VERIFY_SSL=false

# Зеркало из нескольких панелей 3x-ui: JSON-массив в ОДНОЙ строке (многострочный { ... } в .env ломает парсер).
# Можно одну ноду как объект в массиве: [{"url":"...","username":"...", ...}]
# Если задан — используются только эти узлы; XUI_URL / XUI_USERNAME / XUI_PASSWORD не подмешиваются.
# Пример см. DEPLOY.md (раздел «Два узла 3x-ui»).
XUI_NODES=

# ─── USDT / TON ────────────────────────────
# Реальный адрес из кошелька (UQ… / EQ…). Заглушка UQxxxxx… даёт ошибку toncenter 422.
TON_WALLET=
USDT_TRC20_WALLET=TXxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Опционально: https://toncenter.com/api/v2/getApiKey (выше лимит запросов)
TONCENTER_API_KEY=

# ─── Freekassa (опционально, только IPN) ───
# В меню бота способ оплаты Freekassa не показывается. Переменные нужны только если
# оставляете webhook https://ваш-домен/payment/freekassa для старых платежей.
# FREEKASSA_MERCHANT_ID=
# FREEKASSA_SECRET1=
# FREEKASSA_SECRET2=
# 1 = отклонять IPN не с IP Freekassa (нужен корректный X-Real-IP от nginx)
FREEKASSA_WEBHOOK_STRICT_IP=0

# Лимит GET /miniapp/api/* с одного IP в минуту (0 = выключить)
MINIAPP_API_RATE_LIMIT_PER_MIN=60

# ─── Перевод по ссылке (часто Т-Банк tinkoff.ru/rm/... или Сбер pbpn) ───
# Если SBER_PBPN_URL задан — в меню пункт «Перевод (Т-Банк)»; оплата вручную, подтверждение админом.
# Примеры: https://www.tinkoff.ru/rm/... или https://www.sberbank.com/sms/pbpn?requisiteNumber=...
SBER_PBPN_URL=
# 1 = дописать в URL параметр amount= (для Сбера иногда пробуют; для Т-Банка обычно 0)
SBER_PBPN_APPEND_AMOUNT=0

# ─── Т-Банк (интернет-эквайринг, карта / СБП) ─
# TerminalKey и пароль — в Т-Бизнес → Оплата → терминал. Webhook: POST https://ваш-домен/payment/tbank (см. DEPLOY.md)
TBANK_TERMINAL_KEY=
TBANK_PASSWORD=
# 1 = тестовый API (rest-api-test.tinkoff.ru)
TBANK_TEST_MODE=0
# Необязательно: свой базовый URL v2 API без /Init
# TBANK_API_BASE=
# Публичный URL сайта без слэша — для Success/Fail/Notification в Init (или задайте NotificationURL только в кабинете)
PAYMENT_PUBLIC_BASE_URL=

# Опционально: базовый URL для ссылок в помощи (если отличается от PAYMENT_PUBLIC_BASE_URL). Для /geo/geoip.dat в текстах «Как подключиться»
# PUBLIC_WEB_BASE_URL=

# Geo-файлы v2ray (runetfreedom/russia-v2ray-rules-dat): бот отдаёт GET /geo/geoip.dat и /geo/geosite.dat (кэш на диске). 0 = выключить маршруты
# V2RAY_GEO_ENABLED=1
# V2RAY_GEO_GEOIP_URL=https://raw.githubusercontent.com/runetfreedom/russia-v2ray-rules-dat/release/geoip.dat
# V2RAY_GEO_GEOSITE_URL=https://raw.githubusercontent.com/runetfreedom/russia-v2ray-rules-dat/release/geosite.dat
# V2RAY_GEO_CACHE_TTL_SEC=21600

# ─── База данных ───────────────────────────
DATABASE_URL=sqlite+aiosqlite:///ninavpn.db
# PostgreSQL пример: postgresql+asyncpg://user:pass@localhost/ninavpn
# Миграции Alembic (синхронный URL): export ALEMBIC_SYNC_DATABASE_URL=postgresql+psycopg2://user:pass@localhost/ninavpn

# ─── Настройки ─────────────────────────────
REMIND_DAYS_BEFORE=3
# Дней к VPN рефереру за каждого приглашённого после его первой успешной оплаты
REFERRAL_BONUS_DAYS=30
# Дней к VPN приглашённому при первой оплате (/start ref…). 0 = выключено; например 7 — бонус другу
REFERRAL_INVITEE_BONUS_DAYS=0
